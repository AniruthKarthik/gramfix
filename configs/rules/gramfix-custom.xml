<?xml version="1.0" encoding="UTF-8"?>
<!--
  GramFix custom LanguageTool rules.
  Loaded via: java -jar languagetool-commandline.jar
              -rulefile gramfix-custom.xml -language en-US

  Each rule targets a pattern that is either:
    (a) not covered by LT default English ruleset, or
    (b) a high-precision complement to a built-in rule.

  Rule ID naming convention: GRAMFIX_<CATEGORY>_<SHORTNAME>

  IMPORTANT: The double-dash sequence is forbidden inside XML comments.
  Use single dashes or reword. Test this file with:
    java -jar languagetool-commandline.jar
         -rulefile gramfix-custom.xml -language en-US /dev/null
-->
<rules lang="en">

  <!-- ================================================================
       CATEGORY: MODAL VERB ERRORS
       "could/should/would/must/might of" -> "...have"
       LT has MODAL_OF and COULD_OF but they may not catch all variants.
       These rules provide belt-and-suspenders coverage.
       ================================================================ -->
  <category id="GRAMFIX_MODAL" name="Modal Verb Errors">

    <rule id="GRAMFIX_COULD_OF" name="could of to could have">
      <pattern>
        <token>could</token>
        <token>of</token>
      </pattern>
      <message>Did you mean <suggestion>could have</suggestion>?
        "Could of" is a misspelling of "could have" (or "could've").</message>
      <url>https://www.grammarly.com/blog/could-have-vs-could-of/</url>
      <example correction="could have">I <marker>could of</marker> handled that better.</example>
    </rule>

    <rule id="GRAMFIX_SHOULD_OF" name="should of to should have">
      <pattern>
        <token>should</token>
        <token>of</token>
      </pattern>
      <message>Did you mean <suggestion>should have</suggestion>?</message>
      <example correction="should have">You <marker>should of</marker> known.</example>
    </rule>

    <rule id="GRAMFIX_WOULD_OF" name="would of to would have">
      <pattern>
        <token>would</token>
        <token>of</token>
      </pattern>
      <message>Did you mean <suggestion>would have</suggestion>?</message>
      <example correction="would have">She <marker>would of</marker> helped.</example>
    </rule>

    <rule id="GRAMFIX_MUST_OF" name="must of to must have">
      <pattern>
        <token>must</token>
        <token>of</token>
      </pattern>
      <message>Did you mean <suggestion>must have</suggestion>?</message>
      <example correction="must have">He <marker>must of</marker> left early.</example>
    </rule>

    <rule id="GRAMFIX_MIGHT_OF" name="might of to might have">
      <pattern>
        <token>might</token>
        <token>of</token>
      </pattern>
      <message>Did you mean <suggestion>might have</suggestion>?</message>
      <example correction="might have">They <marker>might of</marker> missed it.</example>
    </rule>

  </category>

  <!-- ================================================================
       CATEGORY: THEIR / THEY'RE CONFUSION
       "their going" is a common confusion that LT's n-gram model handles
       when ngram data is available, but the pattern-based rule below
       catches the most common case without requiring n-gram data.
       ================================================================ -->
  <category id="GRAMFIX_THEIR_THEYRE" name="Their vs They are">

    <!--
      Pattern: "Their" + verb-like token (be, go, come, want, etc.)
      This is the most common case: "Their going to the store."
      We check for a set of common verbs that cannot follow a possessive.
    -->
    <rulegroup id="GRAMFIX_THEIR_VERB" name="their + verb (likely they are)">

      <rule>
        <pattern>
          <token regexp="yes">[Tt]heir</token>
          <token>going</token>
        </pattern>
        <message>Did you mean <suggestion>They're going</suggestion> (they are going)?
          "Their" is possessive; "they're" means "they are".</message>
        <example correction="They're going">
          <marker>Their going</marker> to the store after work.
        </example>
      </rule>

      <rule>
        <pattern>
          <token regexp="yes">[Tt]heir</token>
          <token>coming</token>
        </pattern>
        <message>Did you mean <suggestion>They're coming</suggestion>?</message>
        <example correction="They're coming"><marker>Their coming</marker> to the party.</example>
      </rule>

      <rule>
        <pattern>
          <token regexp="yes">[Tt]heir</token>
          <token>trying</token>
        </pattern>
        <message>Did you mean <suggestion>They're trying</suggestion>?</message>
        <example correction="They're trying"><marker>Their trying</marker> to help.</example>
      </rule>

      <rule>
        <pattern>
          <token regexp="yes">[Tt]heir</token>
          <token>working</token>
        </pattern>
        <message>Did you mean <suggestion>They're working</suggestion>?</message>
        <example correction="They're working"><marker>Their working</marker> on it.</example>
      </rule>

      <rule>
        <pattern>
          <token regexp="yes">[Tt]heir</token>
          <token>planning</token>
        </pattern>
        <message>Did you mean <suggestion>They're planning</suggestion>?</message>
        <example correction="They're planning"><marker>Their planning</marker> to leave.</example>
      </rule>

    </rulegroup>

  </category>

  <!-- ================================================================
       CATEGORY: SUBJECT-VERB AGREEMENT (SIMPLE CASES)
       Rules for the most common s-v agreement errors not caught by LT.
       ================================================================ -->
  <category id="GRAMFIX_SV_AGREEMENT" name="Subject-Verb Agreement">

    <!--
      "the X require" / "the X provide" / etc. (singular subject + bare verb)
      LT catches agreement at sentence start but not mid-sentence.
    -->
    <rulegroup id="GRAMFIX_SINGULAR_VERB" name="Singular noun + bare plural verb">

      <rule id="GRAMFIX_PROJECT_REQUIRE" name="project require to project requires">
        <pattern>
          <token regexp="yes">project|report|system|policy|plan|analysis|company|document|program|issue|task|goal|strategy|process|solution|budget|proposal|study|review|survey|product|service|feature|module|component</token>
          <token>require</token>
        </pattern>
        <message>The singular subject needs a third-person singular verb.
          Did you mean <suggestion>requires</suggestion>?</message>
        <example correction="requires">The project <marker>require</marker> more resources.</example>
      </rule>

      <rule id="GRAMFIX_PROJECT_PROVIDE" name="project provide to project provides">
        <pattern>
          <token regexp="yes">project|report|system|policy|plan|analysis|company|document|program|issue|task|goal|strategy|process|solution|budget|proposal|study|review|survey|product|service|feature|module|component</token>
          <token>provide</token>
        </pattern>
        <message>Did you mean <suggestion>provides</suggestion>?</message>
        <example correction="provides">The system <marker>provide</marker> the data.</example>
      </rule>

      <rule id="GRAMFIX_PROJECT_SHOW" name="project show to project shows">
        <pattern>
          <token regexp="yes">project|report|result|analysis|study|review|survey|test|data</token>
          <token>show</token>
        </pattern>
        <message>Did you mean <suggestion>shows</suggestion>?</message>
        <example correction="shows">The analysis <marker>show</marker> a trend.</example>
      </rule>

      <rule id="GRAMFIX_PROJECT_NEED" name="project need to project needs">
        <pattern>
          <token regexp="yes">project|report|system|policy|plan|team|company|program|issue|task|process|solution|product|service|feature|module|component</token>
          <token>need</token>
        </pattern>
        <message>Did you mean <suggestion>needs</suggestion>?</message>
        <example correction="needs">The project <marker>need</marker> approval.</example>
      </rule>

    </rulegroup>

  </category>

  <!-- ================================================================
       CATEGORY: COMMON MISSPELLINGS
       High-precision one-to-one spelling corrections.
       ================================================================ -->
  <category id="GRAMFIX_SPELLING" name="Common Misspellings">

    <rule id="GRAMFIX_ALOT" name="alot to a lot">
      <pattern><token>alot</token></pattern>
      <message>Did you mean <suggestion>a lot</suggestion>? "Alot" is not a standard word.</message>
      <example correction="a lot">I learned <marker>alot</marker> today.</example>
    </rule>

    <rule id="GRAMFIX_IRREGARDLESS" name="irregardless to regardless">
      <pattern><token regexp="yes">irregardless|irregardlessly</token></pattern>
      <message>Did you mean <suggestion>regardless</suggestion>?
        "Irregardless" is non-standard. Use "regardless".</message>
      <example correction="regardless"><marker>Irregardless</marker> of the outcome, we continue.</example>
    </rule>

    <rule id="GRAMFIX_SUPPOSABLY" name="supposably to supposedly">
      <pattern><token>supposably</token></pattern>
      <message>Did you mean <suggestion>supposedly</suggestion>?</message>
      <example correction="supposedly">It was <marker>supposably</marker> finished.</example>
    </rule>

    <rule id="GRAMFIX_DEFINATELY" name="definately to definitely">
      <pattern><token regexp="yes">definately|definitly|definetly|definantly</token></pattern>
      <message>Did you mean <suggestion>definitely</suggestion>?</message>
      <example correction="definitely">I will <marker>definately</marker> attend.</example>
    </rule>

    <rule id="GRAMFIX_OCCURANCE" name="occurance to occurrence">
      <pattern><token regexp="yes">occurance|occurrance|occurence|ocurrence</token></pattern>
      <message>Did you mean <suggestion>occurrence</suggestion>?</message>
      <example correction="occurrence">The <marker>occurance</marker> of errors increased.</example>
    </rule>

    <rule id="GRAMFIX_OCCURED" name="occured to occurred">
      <pattern><token regexp="yes">occured|occuring</token></pattern>
      <message>Did you mean <suggestion>occurred</suggestion>?</message>
      <example correction="occurred">The error <marker>occured</marker> yesterday.</example>
    </rule>

    <rule id="GRAMFIX_RECIEVE" name="recieve to receive">
      <pattern><token regexp="yes">recieve|recieved|recieves|recieving|reciept</token></pattern>
      <message>Did you mean <suggestion>receive</suggestion>?</message>
      <example correction="receive">Did you <marker>recieve</marker> the message?</example>
    </rule>

    <rule id="GRAMFIX_SEPERATE" name="seperate to separate">
      <pattern><token regexp="yes">seperate|seperated|seperates|seperating|seperation</token></pattern>
      <message>Did you mean <suggestion>separate</suggestion>?</message>
      <example correction="separate">Keep them <marker>seperate</marker>.</example>
    </rule>

    <rule id="GRAMFIX_UNTILL" name="untill to until">
      <pattern><token regexp="yes">untill|untl</token></pattern>
      <message>Did you mean <suggestion>until</suggestion>?</message>
      <example correction="until">Wait <marker>untill</marker> tomorrow.</example>
    </rule>

    <rule id="GRAMFIX_ANALYSE_EN_US" name="analyse to analyze (American English)">
      <pattern><token regexp="yes">analyse|analyses|analysed|analysing</token></pattern>
      <message>In American English, use <suggestion>analyze</suggestion> (not "analyse").</message>
      <example correction="analyze">We need to <marker>analyse</marker> the data.</example>
    </rule>

    <!--
      GRAMFIX_CHILDRENS: disabled - LT Hunspell fires first and suggests
      "children's" (possessive). Rely on built-in Hunspell instead.
    -->

    <rule id="GRAMFIX_INFORMATIONS" name="informations to information">
      <pattern><token regexp="yes">informations</token></pattern>
      <message>Did you mean <suggestion>information</suggestion>?
        "Information" is an uncountable noun and has no plural form.</message>
      <example correction="information">The <marker>informations</marker> are available online.</example>
    </rule>

    <rule id="GRAMFIX_ADVISE_NOUN" name="advise used as noun to advice">
      <pattern>
        <token regexp="yes">your|his|her|their|my|our|some|good|bad|any|this|that|the</token>
        <token>advise</token>
      </pattern>
      <message>Did you mean <suggestion>advice</suggestion>?
        "Advice" is the noun; "advise" is the verb.</message>
      <example correction="advice">Thank you for your <marker>advise</marker>.</example>
    </rule>

  </category>

  <!-- ================================================================
       CATEGORY: CONFUSION PAIRS (backup for when n-gram data is absent)
       ================================================================ -->
  <category id="GRAMFIX_CONFUSION" name="Confusion Pair Backups">

    <!--
      "effect" used as a verb (should be "affect")
      Pattern: modal/auxiliary + "effect" + object
    -->
    <rule id="GRAMFIX_EFFECT_VERB" name="effect as verb to affect">
      <pattern>
        <token regexp="yes">will|can|could|would|should|may|might|does|did|to</token>
        <token>effect</token>
        <token regexp="yes">\w+</token>
      </pattern>
      <message>Did you mean <suggestion>affect</suggestion>?
        "Effect" is usually a noun; "affect" is the verb meaning "to influence".</message>
      <example correction="affect">The new policy will <marker>effect everyone</marker> in the company.</example>
    </rule>

    <!--
      "everyday" used where "every day" is needed (adverbial use)
      Pattern: "everyday" + verb
    -->
    <rule id="GRAMFIX_EVERYDAY_ADV" name="everyday (adjective) vs every day (adverb)">
      <pattern>
        <token regexp="yes">everyday</token>
        <token postag="VBZ|VBP|VBD|VB|VBG|VBN" postag_regexp="yes"/>
      </pattern>
      <message>Did you mean <suggestion>every day</suggestion>?
        "Everyday" (one word) is an adjective meaning "ordinary".
        "Every day" (two words) means "each day".</message>
      <example correction="every day">I exercise <marker>everyday</marker> to stay healthy.</example>
    </rule>

  </category>

</rules>
